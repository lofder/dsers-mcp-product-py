# ─── Provider Selection / Provider 选择 ──────────────────────────
# Which provider module to load.
# 选择加载哪个 Provider 模块。
#   dsers_provider.provider            — DSers adapter (default) / DSers 适配器（默认）
#   dropship_import_mcp.mock_provider  — offline mock / 离线模拟（开发用）
# IMPORT_PROVIDER_MODULE=dsers_provider.provider

# ─── DSers Credentials / DSers 凭据 ─────────────────────────────
# Required when using the DSers provider.
# 使用 DSers Provider 时必填。
DSERS_EMAIL=your-email@example.com
DSERS_PASSWORD=your-password

# Environment: "production" or "test"
# 环境："production"（生产）或 "test"（测试）
DSERS_ENV=production

# Or set the base URL directly (overrides DSERS_ENV):
# 或直接设置 API 地址（覆盖 DSERS_ENV）：
# DSERS_BASE_URL=https://bff-api-gw.dsers.com

# ─── DSers Optional / DSers 可选配置 ────────────────────────────
# Modules to load in vendor library (comma-separated).
# Default: account,product,order,logistics,settings
# 加载的业务模块（逗号分隔），默认全部加载。
# DSERS_MODULES=account,product,settings

# Session cache file path (auto-managed, rarely needs override)
# Session 缓存文件路径（自动管理，通常无需修改）
# DSERS_SESSION_FILE=/path/to/.session.json
# PRIVATE_DSERS_SESSION_FILE=/path/to/session-cache/dsers-test-session.json

# Source app IDs (defaults work for most test accounts)
# 来源 App ID（默认值适用于大多数测试账户）
# PRIVATE_DSERS_ALIEXPRESS_APP_ID=159831080
# PRIVATE_DSERS_ALIBABA_APP_ID=1902659021782450176

# Vendor library directory (auto-detected from project layout)
# Vendor 库目录（从项目布局自动检测）
# DSERS_PROVIDER_LIB_DIR=/absolute/path/to/vendor-dsers

# ─── MCP Server / MCP 服务器 ────────────────────────────────────
# State directory for job persistence
# 作业状态持久化目录
# IMPORT_MCP_STATE_DIR=.state

# ─── Shopify Fallback (optional) / Shopify 备用（可选）──────────
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxx
